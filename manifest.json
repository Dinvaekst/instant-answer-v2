{
  "manifest_version": 3,
  "name": "Instant Answer",
  "version": "3.0",
  "description": "Smart AI browser assistant with chat, PDF, math, YouTube and page understanding",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://instant-answer-backend-clean.onrender.com/*"
  ]
}